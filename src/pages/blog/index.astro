---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getPublishedPosts } from '../../lib/blog';

const posts = await getPublishedPosts();

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BlogLayout title="Blog" description="Writing about NLP, computational linguistics, and building things.">
  <div class="blog-header">
    <h1 class="blog-header-title">Blog</h1>
    <p class="blog-header-desc">Writing about NLP, computational linguistics, and building things.</p>
  </div>

  {posts.length > 0 ? (
    <div class="blog-grid">
      {posts.map((post) => (
        <a href={`${import.meta.env.BASE_URL}/blog/${post.slug}`} class="blog-card" data-color={post.data.color}>
          <h2 class="blog-card-title">{post.data.title}</h2>
          <p class="blog-card-desc">{post.data.description}</p>
          <div class="blog-card-meta">
            <span class="blog-card-date">{formatDate(post.data.date)}</span>
            {post.data.tags?.map((tag) => (
              <span class="blog-card-tag">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="blog-empty">
      <p>No posts yet. Check back soon.</p>
    </div>
  )}
</BlogLayout>
